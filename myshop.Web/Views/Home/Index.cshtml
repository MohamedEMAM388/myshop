@{
    Layout = User.IsInRole("Admin")
        ? "~/Views/Shared/_Layout.cshtml"
        : "~/Views/Shared/_Customer.cshtml";

    ViewData["Title"] = "Home";
}

<style>
    .hero-section {
        padding: 70px 0;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 800;
        color: #0d6efd;
        margin-bottom: 25px;
    }

    .hero-text {
        font-size: 1.35rem;
        color: #6c757d;
        line-height: 1.8;
        margin-bottom: 35px;
    }

    .hero-btn {
        padding: 14px 32px;
        font-size: 1.1rem;
        border-radius: 12px;
        margin-right: 10px;
        transition: .3s;
    }

        .hero-btn:hover {
            transform: translateY(-3px);
        }

    .hero-image-card {
        background: white;
        border-radius: 25px;
        padding: 25px;
        box-shadow: 0 20px 45px rgba(0,0,0,.12);
        transition: .4s;
    }

        .hero-image-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 60px rgba(0,0,0,.18);
        }

    .hero-image {
        width: 100%;
        border-radius: 18px;
    }

    .features {
        margin-top: 80px;
    }

    .feature-box {
        background: white;
        border-radius: 18px;
        padding: 35px 25px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        transition: .3s;
        height: 100%;
    }

        .feature-box:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 40px rgba(0,0,0,.15);
        }

    .feature-icon {
        font-size: 50px;
        color: #0d6efd;
        margin-bottom: 20px;
    }

    .feature-title {
        color: #0d6efd;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .feature-text {
        color: #6c757d;
    }
</style>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container hero-section">

    <div class="row align-items-center">

        <div class="col-lg-6">

            <h1 class="hero-title">
                Welcome to myShop
            </h1>

            <p class="hero-text">
                Discover premium products at unbeatable prices.
                Browse categories, explore our latest collections,
                and enjoy a secure and seamless shopping experience.
            </p>

            <a asp-controller="Product"
               asp-action="Index"
               class="btn btn-primary hero-btn">
                <i class="bi bi-cart-fill"></i>
                Shop Now
            </a>

            <a asp-controller="Category"
               asp-action="Index"
               class="btn btn-outline-primary hero-btn">
                <i class="bi bi-grid"></i>
                Browse Categories
            </a>

        </div>

        <div class="col-lg-6">

            <div class="hero-image-card">

                <img src="~/img/shopping.jpg"
                     class="hero-image"
                     alt="Shopping">

            </div>

        </div>

    </div>

    <hr class="my-5" />

    <div class="row features">

        <div class="col-md-4 mb-4">

            <div class="feature-box">

                <div class="feature-icon">
                    <i class="bi bi-truck"></i>
                </div>

                <h3 class="feature-title">
                    Fast Delivery
                </h3>

                <p class="feature-text">
                    We deliver your orders quickly and safely wherever you are.
                </p>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="feature-box">

                <div class="feature-icon">
                    <i class="bi bi-credit-card"></i>
                </div>

                <h3 class="feature-title">
                    Secure Payment
                </h3>

                <p class="feature-text">
                    Shop confidently using safe and trusted payment methods.
                </p>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="feature-box">

                <div class="feature-icon">
                    <i class="bi bi-award"></i>
                </div>

                <h3 class="feature-title">
                    Premium Quality
                </h3>

                <p class="feature-text">
                    Every product is carefully selected to ensure the highest quality.
                </p>

            </div>

        </div>

    </div>

</div>