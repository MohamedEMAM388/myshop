@model myShop.BLL.DTOS.Account.LoginDTO

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Login</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            font-family:Poppins,sans-serif;
        }

        body{
            margin:0;
            height:100vh;
            background:#edf2f7;
            display:flex;
            justify-content:center;
            align-items:center;
        }

        .login-container{
            width:1000px;
            max-width:95%;
            min-height:600px;
            display:flex;
            overflow:hidden;
            border-radius:20px;
            background:white;
            box-shadow:0 20px 45px rgba(0,0,0,.12);
        }

        .left-side{
            width:45%;
            background:linear-gradient(160deg,#163c87,#3d82f6);
            color:white;
            display:flex;
            justify-content:center;
            align-items:center;
            flex-direction:column;
            padding:40px;
        }

        .left-side h1{
            font-size:40px;
            font-weight:700;
            margin-bottom:15px;
        }

        .left-side p{
            text-align:center;
            opacity:.9;
            line-height:1.8;
            font-size:15px;
        }

        .right-side{
            width:55%;
            padding:60px;
            display:flex;
            flex-direction:column;
            justify-content:center;
        }

        .title{
            font-size:34px;
            font-weight:700;
            color:#163c87;
        }

        .subtitle{
            color:#777;
            margin-bottom:35px;
        }

        .form-control{
            height:55px;
            border-radius:12px;
            border:1px solid #ddd;
            margin-bottom:20px;
        }

        .form-control:focus{
            border-color:#3d82f6;
            box-shadow:none;
        }

        .btn-login{
            height:55px;
            border:none;
            border-radius:12px;
            background:linear-gradient(to right,#163c87,#3d82f6);
            color:white;
            font-size:18px;
            font-weight:600;
            transition:.3s;
        }

        .btn-login:hover{
            transform:translateY(-2px);
            box-shadow:0 10px 20px rgba(61,130,246,.35);
        }

        .validation-summary-errors ul{
            padding-left:18px;
            color:red;
        }

        .register-link{
            text-align:center;
            margin-top:25px;
        }

        .register-link a{
            text-decoration:none;
            color:#163c87;
            font-weight:600;
        }

        @@media(max-width:900px){

            .login-container{
                flex-direction:column;
            }

            .left-side,
            .right-side{
                width:100%;
            }

            .left-side{
                min-height:250px;
            }

        }

    </style>

</head>
<body>

    <div class="login-container">

        <div class="left-side">

            <h1>myShop</h1>

            <p>
                Welcome Back!

                <br /><br />

                Sign in to manage your products,
                categories and users through
                the Admin Dashboard.
            </p>

        </div>

        <div class="right-side">

            <h2 class="title">Login</h2>

            <p class="subtitle">
                Sign in to continue
            </p>

            <form asp-action="Login" method="post">

                @Html.ValidationMessage("InvalidLogin", "", new { @class = "text-danger d-block mb-3" })

                <span asp-validation-for="Email" class="text-danger"></span>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="Email Address" />




                <span asp-validation-for="Password" class="text-danger"></span>
                <input asp-for="Password"
                       class="form-control"
                       placeholder="Password" />

             

                <div class="form-check mb-4">

                    <input asp-for="RememberMe"
                           class="form-check-input" />

                    <label asp-for="RememberMe"
                           class="form-check-label">
                        Remember Me
                    </label>

                </div>

                <button class="btn btn-login w-100">
                    Login
                </button>

            </form>

            <div class="register-link">

                Don't have an account?

                <a asp-action="Register">
                    Register
                </a>

            </div>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>