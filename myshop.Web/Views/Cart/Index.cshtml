@model myShop.BLL.DTOS.ShoppingCart.CartDto

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_Customer.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Cart.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>
            <h2 class="fw-bold">
                <i class="fas fa-shopping-cart text-primary me-2"></i>
                Shopping Cart
            </h2>

            <p class="text-muted mb-0">
                @Model.Items.Sum(x => x.Quantity) Item(s) in your cart
            </p>
        </div>

    </div>

    @if (!Model.Items.Any())
    {
        <div class="empty-cart">

            <img src="https://cdn-icons-png.flaticon.com/512/2038/2038854.png"
                 width="180"
                 class="mb-4" />

            <h3 class="fw-bold">
                Your Cart is Empty
            </h3>

            <p class="text-muted mb-4">
                Looks like you haven't added anything yet.
            </p>

            <a asp-controller="Customer"
               asp-action="Index"
               class="btn btn-primary btn-lg px-5">

                <i class="fas fa-store me-2"></i>
                Continue Shopping

            </a>

        </div>
    }
    else
    {

        <div class="row">

            <!-- Cart Items -->
            <div class="col-lg-8">

                @foreach (var item in Model.Items)
                {

                    <div class="cart-card">

                        <!-- Product Image -->
                        <div class="cart-image">

                            <img src="~/uploads/products/@item.ImageUrl"
                                 class="img-fluid"
                                 alt="@item.ProductName" />

                        </div>

                        <!-- Product Info -->
                        <div class="cart-info">

                            <h4>@item.ProductName</h4>

                            <div class="price mb-3">
                                @item.Price.ToString("0.00") EGP
                            </div>

                            <div class="quantity-box">

                                <!-- Minus -->

                                <form asp-action="DecreaseQuantity" method="post">

                                    <input type="hidden"
                                           name="productId"
                                           value="@item.ProductId" />

                                    <button class="qty-btn">

                                        <i class="fas fa-minus"></i>

                                    </button>

                                </form>

                                <span class="qty-number">

                                    @item.Quantity

                                </span>

                                <!-- Plus -->

                                <form asp-action="IncreaseQuantity" method="post">

                                    <input type="hidden"
                                           name="productId"
                                           value="@item.ProductId" />

                                    <button class="qty-btn">

                                        <i class="fas fa-plus"></i>

                                    </button>

                                </form>

                            </div>

                        </div>

                        <!-- Total -->

                        <div class="cart-total ms-auto">

                            <span>Total</span>

                            <h4>
                                @item.GetTotal().ToString("0.00") EGP
                            </h4>

                        </div>

                        <!-- Remove -->

                        <div class="cart-remove ms-3">

                            <form asp-action="RemoveItem" method="post">

                                <input type="hidden"
                                       name="productId"
                                       value="@item.ProductId" />

                                <button class="remove-btn">

                                    <i class="fas fa-trash"></i>

                                </button>

                            </form>

                        </div>

                    </div>

                }

            </div>

            <!-- Order Summary -->

            <div class="col-lg-4">

                <div class="summary-card">

                    <h3>
                        <i class="fas fa-receipt me-2"></i>
                        Order Summary
                    </h3>

                    <div class="summary-item">

                        <span>Items</span>

                        <strong>
                            @Model.Items.Sum(x => x.Quantity)
                        </strong>

                    </div>

                    <div class="summary-item">

                        <span>Subtotal</span>

                        <strong>

                            @Model.OrderTotal.ToString("0.00") EGP

                        </strong>

                    </div>

                    <div class="summary-item">

                        <span>Shipping</span>

                        <strong class="text-success">

                            Free

                        </strong>

                    </div>

                    <hr />

                    <div class="summary-total">

                        <span>Total</span>

                        <h3>

                            @Model.OrderTotal.ToString("0.00") EGP

                        </h3>

                    </div>

                    <button class="checkout-btn mt-3">

                        <i class="fas fa-credit-card me-2"></i>

                        Proceed to Checkout

                    </button>

                    <form asp-action="ClearCart" method="post">

                        <button class="clear-btn mt-3">

                            <i class="fas fa-trash-alt me-2"></i>

                            Clear Cart

                        </button>

                    </form>

                </div>

            </div>

        </div>

    }

</div>