@using myShop.BLL.Services.Interfaces
@inject ICartService CartService
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <title>myShop</title>

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
          rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>

        body {
            background: linear-gradient(
                135deg,
                #eef2f7 0%,
                #d9e4f5 40%,
                #c3dafe 100%
            );

            min-height: 100vh;
            margin: 0;
            padding: 0;
            animation: fadeIn 0.8s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        nav.navbar {
            background: linear-gradient(
                90deg,
                #ffffff,
                #f8fbff
            ) !important;

            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.10);

            padding: 0.8rem 0 !important;

            position: relative;

            z-index: 10;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.7rem;
            letter-spacing: 0.5px;
        }

        .nav-link-box {
            background: linear-gradient(
                135deg,
                #00c6ff 0%,
                #0072ff 100%
            );

            color: white !important;

            padding: 0.65rem 1.2rem;

            margin-left: 10px;

            border-radius: 14px;

            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);

            transition: all 0.3s ease;

            text-align: center;

            font-weight: 600;
        }

        .nav-link-box:hover {
            transform: translateY(-3px);

            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.25);
        }

        .home-box {
            padding: 0.8rem 1.5rem;

            font-size: 1.05rem;
        }

        .cart-btn {
            display: flex;

            align-items: center;

            gap: 8px;

            padding: 0.7rem 1.3rem;

            border-radius: 14px;
        }

        main {
            min-height: calc(100vh - 150px);

            padding: 0;

            animation: fadeIn 1s ease-in-out;
        }

        footer {
            background: linear-gradient(
                90deg,
                #0b0b0b,
                #1a1a1a
            );

            border-top-left-radius: 30px;

            border-top-right-radius: 30px;

            padding: 2rem 0;

            color: white;

            text-align: center;

            margin-top: 50px;
        }

        @@media (max-width: 991px) {

            .nav-link-box {
                margin: 8px 0;
            }

        }

    </style>
        @await RenderSectionAsync("Styles", required: false)

</head>


<body>


    @{
      
        var cart = CartService.GetCart();

       
        var cartCount = cart?.Items?.Sum(x => x.Quantity) ?? 0;
    }


    <!-- =========================
         NAVBAR
    ========================= -->

    <nav class="navbar navbar-expand-lg">

        <div class="container">


            <!-- LOGO -->

            <a class="navbar-brand text-primary"
               href="/Customer/Index">

                myShop

            </a>


            <!-- MOBILE BUTTON -->

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent">

                <span class="navbar-toggler-icon"></span>

            </button>


            <!-- NAVBAR CONTENT -->

            <div class="collapse navbar-collapse"
                 id="navbarSupportedContent">


                <!-- LEFT SIDE -->

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">


                    <!-- HOME -->

                    <li class="nav-item">

                        <a class="nav-link-box home-box nav-link active"
                           href="/Customer/Index">

                            <i class="bi bi-house-door-fill"></i>

                            Home

                        </a>

                    </li>


                </ul>


                <!-- LOGIN PARTIAL -->

                <div class="nav-link-box">

                    <partial name="_LoginPartial" />

                </div>


                <!-- CART -->

                <a href="/Cart/Index"
                   class="nav-link-box cart-btn">


                    <i class="bi bi-cart-fill"></i>


                    Cart


                    <span id="cart-count"
                          class="badge bg-dark text-white rounded-pill">

                        @cartCount

                    </span>


                </a>


            </div>

        </div>

    </nav>


    <!-- =========================
         PAGE CONTENT
    ========================= -->

    <main>

        @RenderBody()

    </main>


    <!-- =========================
         FOOTER
    ========================= -->

    <footer>

        <small>

            &copy; 2026 myShop. All Rights Reserved.

        </small>

    </footer>


    <!-- Bootstrap JS -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
    </script>


    @await RenderSectionAsync("Scripts", required: false)


</body>

</html>